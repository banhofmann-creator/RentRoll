# === RentRoll App ===
# Copy this file to .env and fill in the values.

# Required: Anthropic API key — used for Claude chatbot
ANTHROPIC_API_KEY=sk-ant-...

# Required: Session secret for cookie signing (generate a random string)
SESSION_SECRET=change-me-to-a-random-string

# PostgreSQL connection (Docker Compose sets these automatically)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rentroll
POSTGRES_USER=rentroll
POSTGRES_PASSWORD=rentroll

# Optional: Upload directory path (defaults to /app/uploads in Docker)
UPLOAD_DIR=/app/uploads

# Optional: Redis URL for Celery job queue (Phase 9+)
# REDIS_URL=redis://redis:6379/0
